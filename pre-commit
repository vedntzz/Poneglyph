#!/usr/bin/env bash
# .claude/hooks/pre-commit
#
# Pre-commit hook for Poneglyph. Blocks sloppy commits.
#
# Runs on every `git commit`. If any check fails, commit is aborted.
# Override with `git commit --no-verify` ONLY in genuine emergencies
# (and document the reason in the session log).
#
# Install:
#   1. Place this file at .claude/hooks/pre-commit (already done if you're reading this)
#   2. Symlink to git hooks: ln -s ../../.claude/hooks/pre-commit .git/hooks/pre-commit
#   3. Make executable: chmod +x .claude/hooks/pre-commit
#
# What it checks:
#   Python: ruff (lint + format), mypy (type check)
#   TypeScript: tsc --noEmit (type check), eslint (lint)
#   Secrets: basic grep for common API key patterns
#   Session logs: warns if no session log was updated in this commit

set -e

# ANSI colors for readability
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}━━━ Poneglyph pre-commit checks ━━━${NC}"

# ─────────────────────────────────────────────────────────────
# 1. Guard against committing secrets
# ─────────────────────────────────────────────────────────────
echo -e "${BLUE}[1/5]${NC} Scanning for accidentally committed secrets..."

# Check staged files only (not the whole repo)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -n "$STAGED_FILES" ]; then
  # Patterns that should never appear in committed code
  SECRET_PATTERNS=(
    "sk-ant-[a-zA-Z0-9_-]{20,}"         # Anthropic API keys
    "ANTHROPIC_API_KEY\s*=\s*['\"]sk-"  # inline hardcoded keys
    "AKIA[0-9A-Z]{16}"                  # AWS access keys
    "-----BEGIN.*PRIVATE KEY-----"      # private keys
  )

  SECRET_FOUND=false
  for pattern in "${SECRET_PATTERNS[@]}"; do
    # -I skips binary files; -E enables extended regex
    if echo "$STAGED_FILES" | xargs grep -I -E "$pattern" 2>/dev/null; then
      SECRET_FOUND=true
    fi
  done

  if [ "$SECRET_FOUND" = true ]; then
    echo -e "${RED}✗ Potential secret found in staged files. Aborting commit.${NC}"
    echo -e "${RED}  Remove the secret and use env vars (.env is gitignored).${NC}"
    exit 1
  fi
fi
echo -e "${GREEN}✓${NC} No secrets detected"

# ─────────────────────────────────────────────────────────────
# 2. Python checks (ruff + mypy)
# ─────────────────────────────────────────────────────────────
echo -e "${BLUE}[2/5]${NC} Python: ruff lint + format check..."

# Only run if there are staged Python files in /backend
STAGED_PY=$(echo "$STAGED_FILES" | grep -E '^backend/.*\.py$' || true)

if [ -n "$STAGED_PY" ]; then
  cd backend

  # ruff check: lint errors
  if ! ruff check $(echo "$STAGED_PY" | sed 's|^backend/||'); then
    echo -e "${RED}✗ ruff found lint errors. Fix them or run \`ruff check --fix\`.${NC}"
    exit 1
  fi

  # ruff format: verifies files are formatted correctly (does not modify)
  if ! ruff format --check $(echo "$STAGED_PY" | sed 's|^backend/||'); then
    echo -e "${RED}✗ ruff format check failed. Run \`ruff format\` to fix.${NC}"
    exit 1
  fi

  echo -e "${GREEN}✓${NC} ruff passed"

  # mypy: strict type check
  echo -e "${BLUE}[3/5]${NC} Python: mypy type check..."
  if ! mypy --strict $(echo "$STAGED_PY" | sed 's|^backend/||'); then
    echo -e "${RED}✗ mypy found type errors. Fix the types — no \`# type: ignore\` without a comment explaining why.${NC}"
    exit 1
  fi
  echo -e "${GREEN}✓${NC} mypy passed"

  cd ..
else
  echo -e "${YELLOW}⊘${NC} No Python files staged, skipping"
  echo -e "${BLUE}[3/5]${NC} ${YELLOW}⊘${NC} No Python files staged, skipping mypy"
fi

# ─────────────────────────────────────────────────────────────
# 3. TypeScript checks (tsc + eslint)
# ─────────────────────────────────────────────────────────────
echo -e "${BLUE}[4/5]${NC} TypeScript: tsc + eslint..."

STAGED_TS=$(echo "$STAGED_FILES" | grep -E '^frontend/.*\.(ts|tsx)$' || true)

if [ -n "$STAGED_TS" ]; then
  cd frontend

  # tsc --noEmit: type check without generating output files
  # We check the whole project because TS types are cross-file
  if ! npx tsc --noEmit; then
    echo -e "${RED}✗ TypeScript type errors found. No \`any\`, no untyped returns.${NC}"
    exit 1
  fi

  # eslint: lint errors on staged files only
  if ! npx eslint $(echo "$STAGED_TS" | sed 's|^frontend/||'); then
    echo -e "${RED}✗ eslint errors found.${NC}"
    exit 1
  fi

  echo -e "${GREEN}✓${NC} TypeScript passed"

  cd ..
else
  echo -e "${YELLOW}⊘${NC} No TypeScript files staged, skipping"
fi

# ─────────────────────────────────────────────────────────────
# 4. Session log reminder
# ─────────────────────────────────────────────────────────────
# Not a hard block — just a warning. Session logs are a methodology
# discipline, not every commit needs to touch them (small refactors
# are fine), but if a whole session goes by with no log, that's a smell.
echo -e "${BLUE}[5/5]${NC} Session log check..."

STAGED_SESSION=$(echo "$STAGED_FILES" | grep -E '^sessions/.*\.md$' || true)

if [ -z "$STAGED_SESSION" ]; then
  # Check when the last session log was touched (committed or staged)
  LAST_SESSION_COMMIT=$(git log -1 --format=%ct -- 'sessions/*.md' 2>/dev/null || echo "0")
  NOW=$(date +%s)
  # Warn if no session log has been touched in >2 hours
  if [ "$LAST_SESSION_COMMIT" -gt 0 ] && [ $((NOW - LAST_SESSION_COMMIT)) -gt 7200 ]; then
    echo -e "${YELLOW}⚠${NC} No session log updated in >2 hours. Remember to write as you go."
  else
    echo -e "${GREEN}✓${NC} Session logs recent (or first commit)"
  fi
else
  echo -e "${GREEN}✓${NC} Session log staged in this commit"
fi

echo -e "${GREEN}━━━ All pre-commit checks passed ━━━${NC}"
exit 0
